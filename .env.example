# =============================================================================
# House of Piranha — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Shopify Storefront API
# Obtain from: Shopify Admin → Apps → Develop apps → Your App → API credentials
# The Storefront Access Token is safe to expose on the client side.
# -----------------------------------------------------------------------------
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token_here

# -----------------------------------------------------------------------------
# Klaviyo (optional — waitlist email marketing)
# Obtain from: Klaviyo Account → Settings → API Keys
# The PRIVATE key is server-side only — never expose it publicly.
# -----------------------------------------------------------------------------
KLAVIYO_PRIVATE_API_KEY=pk_your_klaviyo_private_key_here
KLAVIYO_LIST_ID=your_klaviyo_list_id_here

# -----------------------------------------------------------------------------
# Site URL (used for canonical URLs, OG tags, etc.)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://www.houseofpiranha.com
